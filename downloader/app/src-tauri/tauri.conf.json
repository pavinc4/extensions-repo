{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Any Downloader",
  "version": "1.0.0",
  "identifier": "com.danhawk.any-downloader",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1421",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": false,
    "windows": [
      {
        "label": "main",
        "title": "Any Downloader",
        "width": 520,
        "height": 620,
        "resizable": false,
        "decorations": false,
        "center": true,
        "visible": false,
        "skipTaskbar": true,
        "devtools": true
      }
    ],
    "security": { "csp": null }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/icon.ico"
    ]
  }
}
