{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Any Downloader",
  "version": "1.0.0",
  "identifier": "com.danhawk.any-downloader",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1421",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": false,
    "windows": [
      {
        "label": "main",
        "title": "Any Downloader",
        "width": 520,
        "height": 620,
        "minWidth": 520,
        "minHeight": 620,
        "maxWidth": 520,
        "resizable": false,
        "decorations": false,
        "center": true,
        "visible": false,
        "alwaysOnTop": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "shell": {
      "open": true,
      "sidecar": true
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "icon": ["icons/icon.ico"],
    "resources": {
      "../../bin/yt-dlp.exe": "bin/yt-dlp.exe",
      "../../bin/ffmpeg.exe":  "bin/ffmpeg.exe"
    },
    "externalBin": [
      "bin/yt-dlp",
      "bin/ffmpeg"
    ]
  }
}
